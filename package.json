{
  "name": "forgestack",
  "version": "1.0.0",
  "private": true,
  "description": "A production-ready NestJS microservices starter: DDD, CQRS, event-driven messaging over Kafka, full observability and one-command deploys.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FVJohnny/forgestack.git"
  },
  "author": "FVJohnny",
  "keywords": [
    "nestjs",
    "microservices",
    "ddd",
    "cqrs",
    "kafka",
    "event-driven",
    "hexagonal-architecture",
    "typescript",
    "starter",
    "boilerplate"
  ],
  "scripts": {
    "build": "nx run-many -t build --exclude=forgestack",
    "typecheck": "./scripts/check-typescript.sh",
    "test": "nx run-many --target=test --all --exclude=forgestack",
    "test:watch": "npm run test -- --watchAll",
    "test:nocache": "npm run test -- --skip-nx-cache",
    "lint": "nx run-many -t lint --exclude=forgestack",
    "lint:fix": "nx run-many -t lint --exclude=forgestack -- --fix",
    "dev:start": "./infra/scripts/start-dev.sh",
    "dev:down": "docker compose -f infra/compose/docker-compose.dev.yml down",
    "dev:logs": "docker compose -f infra/compose/docker-compose.dev.yml logs -f --tail=100",
    "dev:restart": "./infra/scripts/restart-dev.sh",
    "dev:restart:all": "npm run dev:down && npm run dev:start",
    "dev:trust-cert": "./infra/scripts/trust-caddy-cert.sh",
    "prod:setup": "./infra/scripts/prod-setup.sh",
    "prod:update": "./infra/scripts/deploy.sh",
    "nx": "nx"
  },
  "workspaces": [
    "backend/libs/*",
    "backend/services/*",
    "tools/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.34.0",
    "@nx/eslint": "21.5.3",
    "@nx/js": "21.5.3",
    "@nx/node": "21.5.3",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^61.0.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nx": "21.5.3",
    "ts-jest": "^29.4.1",
    "tsconfig-paths-jest": "^0.0.1",
    "typescript-eslint": "^8.42.0"
  },
  "nx": {}
}
