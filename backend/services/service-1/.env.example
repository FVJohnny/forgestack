# =============================================================================
# Service-1 Development Environment Variables
# =============================================================================

NODE_ENV=development
PORT=3000
SERVICE_NAME=service-1
# Display name used in outgoing emails (verification, password reset, etc.)
APP_NAME=ForgeStack

# -----------------------------------------------------------------------------
# Kafka Configuration (Docker)
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka:9092
KAFKA_SERVICE_ID=service-1
KAFKA_USERNAME=
KAFKA_PASSWORD=

# -----------------------------------------------------------------------------
# MongoDB Configuration (Docker)
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://admin:password@mongodb:27017/app?replicaSet=rs0&authSource=admin

# -----------------------------------------------------------------------------
# Redis Configuration (Docker - no auth in dev)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Default User (created automatically if database is empty)
# -----------------------------------------------------------------------------
DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_PASSWORD=Admin123!!??

# -----------------------------------------------------------------------------
# Internal API Key (for /health, /metrics endpoints)
# -----------------------------------------------------------------------------
INTERNAL_API_KEY=dev-internal-api-key

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://localhost,http://localhost
FRONTEND_URL=https://localhost

# -----------------------------------------------------------------------------
# SMTP Configuration (optional for dev)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true


# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=google-client-id