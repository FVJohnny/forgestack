# =============================================================================
# Infrastructure Production Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Domain & Caddy Configuration
# -----------------------------------------------------------------------------
DOMAIN=your-domain.com
PROTOCOL=https
TLS_ENV=prod
# Caddy Basic Auth (for protected endpoints)
# Generate hash: docker run --rm caddy:2.8-alpine caddy hash-password --plaintext 'yourpassword'
CADDY_BASIC_AUTH_HASH=your-bcrypt-hash

# -----------------------------------------------------------------------------
# Docker Registry
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=docker.io/your-username
DOCKER_USER=your-username
DOCKER_PASS=your-docker-pat-token

# -----------------------------------------------------------------------------
# Remote Server Configuration (uses SSH key authentication)
# -----------------------------------------------------------------------------
SERVER_IP=your-server-ip
SERVER_USER=your-username

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASS=your-mongo-password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=your-redis-password

# -----------------------------------------------------------------------------
# Mongo Express
# -----------------------------------------------------------------------------
ME_CONFIG_BASICAUTH_USERNAME=your-mongo-express-username
ME_CONFIG_BASICAUTH_PASSWORD=your-mongo-express-password
