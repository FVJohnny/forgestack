{
  "title": "Inbox/Outbox Metrics Dashboard",
  "uid": "inbox-outbox-metrics",
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "query": "label_values(outbox_events_total, service)",
        "refresh": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "interval",
        "type": "interval",
        "label": "Group by",
        "hide": 0,
        "current": { "text": "1m", "value": "1m" },
        "options": [
          { "text": "10s", "value": "10s", "selected": false },
          { "text": "30s", "value": "30s", "selected": false },
          { "text": "1m", "value": "1m", "selected": true },
          { "text": "5m", "value": "5m", "selected": false },
          { "text": "15m", "value": "15m", "selected": false },
          { "text": "1h", "value": "1h", "selected": false }
        ],
        "query": "10s,30s,1m,5m,15m,1h"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Outbox Publish Rate",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "reqps"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(rate(outbox_events_total{service=~\"$service\", status=\"published\"}[$interval]))",
          "legendFormat": "Published"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Outbox Queue Size",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(outbox_queue_size{service=~\"$service\"})",
          "legendFormat": "Queue"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Outbox Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(rate(outbox_events_total{service=~\"$service\", status=\"failed\"}[$interval])) / sum(rate(outbox_events_total{service=~\"$service\"}[$interval]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Inbox Receive Rate",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "reqps"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(rate(inbox_events_total{service=~\"$service\", status=\"received\"}[$interval]))",
          "legendFormat": "Received"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Inbox Queue Size",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(inbox_queue_size{service=~\"$service\"})",
          "legendFormat": "Queue"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Inbox Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(rate(inbox_events_total{service=~\"$service\", status=\"failed\"}[$interval])) / sum(rate(inbox_events_total{service=~\"$service\"}[$interval]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "type": "row",
      "title": "Outbox",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Outbox Events by Topic",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (topic, event_name) (rate(outbox_events_total{service=~\"$service\", status=\"published\"}[$interval]))",
          "legendFormat": "{{topic}} / {{event_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox Publish Latency (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (topic, le) (rate(outbox_event_duration_seconds_bucket{service=~\"$service\", status=\"published\"}[$interval])))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox Queue Size Over Time",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (service) (outbox_queue_size{service=~\"$service\"})",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox Failed Events",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "short",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (topic, event_name) (increase(outbox_events_total{service=~\"$service\", status=\"failed\"}[$interval]))",
          "legendFormat": "{{topic}} / {{event_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox Retries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never"
          },
          "unit": "short",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (topic, event_name) (increase(outbox_events_total{service=~\"$service\", status=\"retry\"}[$interval]))",
          "legendFormat": "{{topic}} / {{event_name}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Inbox",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false
    },
