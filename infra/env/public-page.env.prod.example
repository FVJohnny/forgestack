# =============================================================================
# Public Page (Frontend) Production Environment Variables
# Copy this file to public-page.env.prod and fill in the values
#
# NOTE: NEXT_PUBLIC_* variables are baked into the build at build time.
# Other variables are available at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration (build-time)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://service1.example.com/api/v1
NEXT_PUBLIC_SERVICE2_API_URL=https://service2.example.com/api/v1

# -----------------------------------------------------------------------------
# Google OAuth (build-time)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
