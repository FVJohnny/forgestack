# =============================================================================
# <%= name %> Production Environment Variables
# Copy this file to <%= name %>.env.prod and fill in the values
# =============================================================================

NODE_ENV=production
PORT=3000
# Must be unique per service — names the service in logs, traces, metrics and Mongo
SERVICE_NAME=<%= name %>

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka:9092
# The Kafka consumer group. MUST be unique per service: each group receives
# every event independently. Sharing another service's id splits the stream.
KAFKA_SERVICE_ID=<%= name %>
KAFKA_USERNAME=
KAFKA_PASSWORD=

# -----------------------------------------------------------------------------
# MongoDB Configuration — each service gets its own database
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://mongodb:27017/<%= name %>?replicaSet=rs0

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DB=0
REDIS_TLS=false

# -----------------------------------------------------------------------------
# JWT Configuration — same secrets as the other services so tokens validate here
# -----------------------------------------------------------------------------
JWT_SECRET=YOUR_JWT_SECRET_CHANGE_IN_PRODUCTION
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET_CHANGE_IN_PRODUCTION
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Internal API Key (for /health, /metrics endpoints) — must match the key
# baked into the Prometheus image
# -----------------------------------------------------------------------------
INTERNAL_API_KEY=YOUR_INTERNAL_API_KEY

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://example.com,https://www.example.com
FRONTEND_URL=https://example.com

# -----------------------------------------------------------------------------
# OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
