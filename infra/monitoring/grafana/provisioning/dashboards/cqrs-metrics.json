      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(cqrs_command_duration_seconds_bucket{service=~\"$service\"}[$interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(cqrs_command_duration_seconds_bucket{service=~\"$service\"}[$interval])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cqrs_command_duration_seconds_bucket{service=~\"$service\"}[$interval])) by (le))",
          "legendFormat": "p95"
