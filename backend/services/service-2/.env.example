# =============================================================================
# Service-2 Development Environment Variables
# =============================================================================

NODE_ENV=development
PORT=3000
# Must be unique per service — names the service in logs, traces, metrics and Mongo
SERVICE_NAME=service-2
APP_NAME=ForgeStack

# -----------------------------------------------------------------------------
# Kafka Configuration (Docker)
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka:9092
# The Kafka consumer group. MUST be unique per service: each group receives
# every event independently. Sharing service-1's id would split the stream.
KAFKA_SERVICE_ID=service-2
KAFKA_USERNAME=
KAFKA_PASSWORD=

# -----------------------------------------------------------------------------
# MongoDB Configuration (Docker) — each service gets its own database
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://admin:password@mongodb:27017/service-2?replicaSet=rs0&authSource=admin

# -----------------------------------------------------------------------------
# Redis Configuration (Docker - no auth in dev)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# -----------------------------------------------------------------------------
# JWT Configuration — same secrets as service-1 so its tokens validate here
# -----------------------------------------------------------------------------
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Internal API Key (for /health, /metrics endpoints)
# -----------------------------------------------------------------------------
INTERNAL_API_KEY=dev-internal-api-key

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://localhost,http://localhost
FRONTEND_URL=https://localhost

# -----------------------------------------------------------------------------
# OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
