    {
      "type": "row",
      "title": "Detailed Tables",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Top Outbox Events (Last 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Topic" },
            "properties": [{ "id": "custom.width", "value": 150 }]
          },
          {
            "matcher": { "id": "byName", "options": "Event" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "Published" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "red", "value": 1 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Retries" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "orange", "value": 1 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Avg Duration" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Published", "desc": true }]
      },
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "event_name", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "topic": "Topic",
              "event_name": "Event",
              "Value #A": "Published",
              "Value #B": "Failed",
              "Value #C": "Retries",
              "Value #D": "Avg Duration"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "round(sum by (topic, event_name) (increase(outbox_events_total{service=~\"$service\", status=\"published\"}[5m])))",
          "legendFormat": "{{event_name}}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "round(sum by (topic, event_name) (increase(outbox_events_total{service=~\"$service\", status=\"failed\"}[5m])))",
          "legendFormat": "{{event_name}}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "round(sum by (topic, event_name) (increase(outbox_events_total{service=~\"$service\", status=\"retry\"}[5m])))",
          "legendFormat": "{{event_name}}",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "sum by (topic, event_name) (rate(outbox_event_duration_seconds_sum{service=~\"$service\", status=\"published\"}[5m])) / sum by (topic, event_name) (rate(outbox_event_duration_seconds_count{service=~\"$service\", status=\"published\"}[5m]))",
          "legendFormat": "{{event_name}}",
          "format": "table",
          "instant": true,
          "refId": "D"
        }
      ]
    },
    {
      "type": "table",
      "title": "Top Inbox Events (Last 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": {
