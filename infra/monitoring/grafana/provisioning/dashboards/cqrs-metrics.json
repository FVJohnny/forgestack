          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(cqrs_commands_total{service=~\"$service\", status=\"error\"}[$interval]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "table",
      "title": "Top Commands (last 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Count" }, "properties": [{ "id": "unit", "value": "short" }] },
          { "matcher": { "id": "byName", "options": "Avg Duration" }, "properties": [{ "id": "unit", "value": "s" }] },
          { "matcher": { "id": "byName", "options": "Error Rate" }, "properties": [{ "id": "unit", "value": "percentunit" }] }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "transformations": [
        { "id": "merge" },
        { "id": "organize", "options": { "renameByName": { "name": "Command", "Value #A": "Count", "Value #B": "Avg Duration", "Value #C": "Error Rate" } } }
      ],
      "targets": [
        {
          "expr": "round(sum by (name) (increase(cqrs_commands_total{service=~\"$service\"}[$interval])))",
          "legendFormat": "{{name}}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum by (name) (rate(cqrs_command_duration_seconds_sum{service=~\"$service\"}[$interval])) / sum by (name) (rate(cqrs_command_duration_seconds_count{service=~\"$service\"}[$interval]))",
          "legendFormat": "{{name}}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "sum by (name) (rate(cqrs_commands_total{service=~\"$service\", status=\"error\"}[$interval])) / sum by (name) (rate(cqrs_commands_total{service=~\"$service\"}[$interval]))",
          "legendFormat": "{{name}}",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ]
    },
