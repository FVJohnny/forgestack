# Don't fail the install when pnpm chooses to skip a dependency's build
# scripts (sharp, @swc/core, @parcel/watcher). These are well-known packages
# whose install scripts download platform-specific native binaries — Next.js
# also lazy-builds what it needs at first dev/build run, so skipping these is
# safe. Without this flag pnpm 10+ exits non-zero with ERR_PNPM_IGNORED_BUILDS,
# which broke the Docker build of the frontend.
strict-dep-builds=false
